<%!-- About Us Preview Section --%>
<section class="py-20 px-4 sm:px-6 lg:px-8 bg-base-100">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
      <.icon name="hero-information-circle-solid" class="size-4" />
      <span>Our Story</span>
    </div>

