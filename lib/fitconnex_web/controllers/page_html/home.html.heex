<%!-- FAQ Section --%>
<section class="py-24 px-4 sm:px-6 lg:px-8 bg-base-200/50">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight">
        Frequently Asked <span class="text-primary">Questions</span>
      </h2>
      <p class="mt-4 text-base-content/60 text-lg">
        Everything you need to know about FitConnex
      </p>
    </div>

    <div class="space-y-4">
      <%!-- FAQ 1 --%>
      <div class="collapse collapse-plus bg-base-100 border border-base-300/50">
        <input type="radio" name="faq-accordion" checked="checked" />
        <div class="collapse-title text-lg font-semibold">
          Is FitConnex free to use?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Yes! Members can sign up and explore gyms completely free. Gym operators have a free starter plan, and we offer paid plans with advanced features for growing businesses.
          </p>
        </div>
      </div>

      <%!-- FAQ 2 --%>
      <div class="collapse collapse-plus bg-base-100 border border-base-300/50">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold">
          How do I find gyms near me?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Simply visit our Explore page, and we'll automatically show you gyms based on your location. You can filter by distance, rating, price, and amenities to find your perfect match.
          </p>
        </div>
      </div>

      <%!-- FAQ 3 --%>
      <div class="collapse collapse-plus bg-base-100 border border-base-300/50">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold">
          Can trainers work independently or only with gyms?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Trainers can work both ways! You can join a gym through an invitation from a gym operator, or work independently and manage your own clients directly on the platform.
          </p>
        </div>
      </div>

      <%!-- FAQ 4 --%>
      <div class="collapse collapse-plus bg-base-100 border border-base-300/50">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold">
          What payment methods do you accept?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            We accept all major credit and debit cards, digital wallets, and bank transfers. All transactions are secure and encrypted for your safety.
          </p>
        </div>
      </div>

      <%!-- FAQ 5 --%>
      <div class="collapse collapse-plus bg-base-100 border border-base-300/50">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold">
          Can I cancel my membership anytime?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Yes! Membership cancellation policies are set by individual gyms. Most gyms offer flexible cancellation options, which you can review before subscribing.
          </p>
        </div>
      </div>

      <%!-- FAQ 6 --%>
      <div class="collapse collapse-plus bg-base-100 border border-base-300/50">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold">
          Do you offer mobile apps?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Our web platform is fully responsive and works seamlessly on mobile browsers. Native iOS and Android apps are coming soon!
          </p>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <p class="text-base-content/60 mb-4">Still have questions?</p>
      <a href="/about" class="btn btn-outline btn-primary">Contact Support</a>
    </div>
  </div>
</section>

<%!-- CTA Section --%>
