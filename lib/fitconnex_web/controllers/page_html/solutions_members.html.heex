<%!-- Hero Section --%>
<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden pt-16">
  <div class="absolute inset-0 bg-gradient-to-br from-accent/5 via-base-100 to-accent/10"></div>
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-accent/15 rounded-full blur-3xl"></div>

  <div class="relative z-10 text-center max-w-4xl mx-auto px-4 sm:px-6 py-20">
    <div class="inline-flex items-center gap-2 bg-accent/10 text-accent px-4 py-1.5 rounded-full text-sm font-semibold mb-8">
      <.icon name="hero-user-solid" class="size-4" />
      <span>For Members</span>
    </div>

    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-tight">
      Your Fitness Journey <span class="text-accent">Starts Here</span>
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-base-content/60 max-w-2xl mx-auto leading-relaxed">
      Discover top-rated gyms, book classes instantly, track your progress, and achieve your fitness goals with personalized workout and diet plans.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/register"
        class="btn btn-accent btn-lg gap-2 shadow-lg shadow-accent/25 font-bold px-8"
      >
        <.icon name="hero-rocket-launch-solid" class="size-5" /> Join as Member
      </a>
      <a href="/explore" class="btn btn-ghost btn-lg gap-2 font-semibold">
        <.icon name="hero-magnifying-glass" class="size-5" /> Explore Gyms
      </a>
    </div>
  </div>
</section>

<%!-- Key Features Section --%>
<section class="py-24 px-4 sm:px-6 lg:px-8 bg-base-200/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight">
        Everything You Need to <span class="text-accent">Succeed</span>
      </h2>
      <p class="mt-4 text-base-content/60 text-lg max-w-2xl mx-auto">
        Powerful features designed to help you reach your fitness goals faster.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%!-- Feature 1 --%>
      <div class="card bg-base-100 shadow-sm hover:shadow-lg border border-base-300/50 p-6">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <.icon name="hero-map-pin-solid" class="size-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold mb-3">Discover Gyms</h3>
        <p class="text-base-content/60 leading-relaxed">
          Find gyms near you with detailed information on facilities, pricing, reviews, and proximity to your location.
        </p>
      </div>

      <%!-- Feature 2 --%>
      <div class="card bg-base-100 shadow-sm hover:shadow-lg border border-base-300/50 p-6">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <.icon name="hero-calendar-days-solid" class="size-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold mb-3">Book Classes</h3>
        <p class="text-base-content/60 leading-relaxed">
          Browse and book fitness classes with real-time availability. Get instant confirmations and reminders.
        </p>
      </div>

      <%!-- Feature 3 --%>
      <div class="card bg-base-100 shadow-sm hover:shadow-lg border border-base-300/50 p-6">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <.icon name="hero-fire-solid" class="size-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold mb-3">Workout Plans</h3>
        <p class="text-base-content/60 leading-relaxed">
          Access personalized workout plans from your trainer with exercises, sets, reps, and progress tracking.
        </p>
      </div>

      <%!-- Feature 4 --%>
      <div class="card bg-base-100 shadow-sm hover:shadow-lg border border-base-300/50 p-6">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <.icon name="hero-heart-solid" class="size-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold mb-3">Diet Plans</h3>
        <p class="text-base-content/60 leading-relaxed">
          Follow customized meal plans with calorie tracking, macro breakdowns, and dietary preference options.
        </p>
      </div>

      <%!-- Feature 5 --%>
      <div class="card bg-base-100 shadow-sm hover:shadow-lg border border-base-300/50 p-6">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <.icon name="hero-chart-bar-solid" class="size-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold mb-3">Track Progress</h3>
        <p class="text-base-content/60 leading-relaxed">
          Monitor attendance, workout completion, and fitness goals with detailed analytics and insights.
        </p>
      </div>

      <%!-- Feature 6 --%>
      <div class="card bg-base-100 shadow-sm hover:shadow-lg border border-base-300/50 p-6">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
          <.icon name="hero-credit-card-solid" class="size-6 text-accent" />
        </div>
        <h3 class="text-xl font-bold mb-3">Flexible Plans</h3>
        <p class="text-base-content/60 leading-relaxed">
          Choose from day passes, monthly, or annual memberships. Manage subscriptions and payments easily.
        </p>
      </div>
    </div>
  </div>
</section>

<%!-- How It Works Section --%>
<section class="py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
