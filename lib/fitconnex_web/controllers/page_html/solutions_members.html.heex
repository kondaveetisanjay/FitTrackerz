      <%!-- Step 3 --%>
      <div class="text-center">
        <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl font-black text-accent">3</span>
        </div>
        <h3 class="text-lg font-bold mb-2">Subscribe</h3>
        <p class="text-base-content/60 text-sm">
          Choose a plan that fits your needs
        </p>
      </div>

      <%!-- Step 4 --%>
      <div class="text-center">
        <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
          <span class="text-2xl font-black text-accent">4</span>
        </div>
        <h3 class="text-lg font-bold mb-2">Start Training</h3>
        <p class="text-base-content/60 text-sm">
