<%!-- FAQ Section --%>
<section class="py-24 px-4 sm:px-6 lg:px-8 bg-base-100">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-brand text-3xl sm:text-4xl">
        FREQUENTLY ASKED <span class="text-primary">QUESTIONS</span>
      </h2>
      <p class="mt-4 text-base-content/60 text-lg">
        Everything you need to know about FitTrackerz
      </p>
    </div>

    <div class="space-y-4">
      <%!-- FAQ 1 --%>
      <div class="collapse collapse-plus glass-card">
        <input type="radio" name="faq-accordion" checked="checked" />
        <div class="collapse-title text-lg font-semibold flex items-center gap-2">
          <.icon name="hero-currency-rupee-solid" class="size-5 text-primary shrink-0" />
          Is FitTrackerz free to use?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Yes! Members can sign up and explore gyms completely free. Gym operators have a free starter plan, and we offer paid plans with advanced features for growing businesses.
          </p>
        </div>
      </div>

      <%!-- FAQ 2 --%>
      <div class="collapse collapse-plus glass-card">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold flex items-center gap-2">
          <.icon name="hero-map-pin-solid" class="size-5 text-primary shrink-0" />
          How do I find gyms near me?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Simply visit our Explore page, and we'll automatically show you gyms based on your location. You can filter by distance, rating, price, and amenities to find your perfect match.
          </p>
        </div>
      </div>


      <%!-- FAQ 4 --%>
      <div class="collapse collapse-plus glass-card">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold flex items-center gap-2">
          <.icon name="hero-credit-card-solid" class="size-5 text-primary shrink-0" />
          What payment methods do you accept?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            We accept all major credit and debit cards, digital wallets, and bank transfers. All transactions are secure and encrypted for your safety.
          </p>
        </div>
      </div>

      <%!-- FAQ 5 --%>
      <div class="collapse collapse-plus glass-card">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold flex items-center gap-2">
          <.icon name="hero-arrow-path-solid" class="size-5 text-primary shrink-0" />
          Can I cancel my membership anytime?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Yes! Membership cancellation policies are set by individual gyms. Most gyms offer flexible cancellation options, which you can review before subscribing.
          </p>
        </div>
      </div>

      <%!-- FAQ 6 --%>
      <div class="collapse collapse-plus glass-card">
        <input type="radio" name="faq-accordion" />
        <div class="collapse-title text-lg font-semibold flex items-center gap-2">
          <.icon name="hero-device-phone-mobile-solid" class="size-5 text-primary shrink-0" />
          Do you offer mobile apps?
        </div>
        <div class="collapse-content">
          <p class="text-base-content/70">
            Our web platform is fully responsive and works seamlessly on mobile browsers. Native iOS and Android apps are coming soon!
          </p>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <p class="text-base-content/60 mb-4">Still have questions?</p>
      <a href="/about" class="btn btn-outline btn-primary font-bold">Contact Support</a>
    </div>
  </div>
</section>

<%!-- CTA Section --%>
<section class="py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-primary/5 via-base-200/50 to-secondary/5 relative overflow-hidden">
  <%!-- Floating decorative elements --%>
  <div class="absolute top-12 left-12 opacity-[0.06] animate-float">
    <.icon name="hero-bolt-solid" class="size-16 text-primary" />
  </div>
  <div class="absolute bottom-12 right-12 opacity-[0.06] animate-float-delayed">
    <.icon name="hero-fire-solid" class="size-14 text-secondary" />
  </div>
  <div class="absolute top-1/3 right-1/4 opacity-[0.04] animate-float-slow">
    <.icon name="hero-sparkles-solid" class="size-12 text-primary" />
  </div>

  <div class="max-w-4xl mx-auto text-center">
    <div class="glass-card p-8 sm:p-12 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-40 h-40 bg-primary/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-32 h-32 bg-secondary/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>

      <div class="relative z-10">
        <div class="flex justify-center mb-4">
          <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center border border-primary/20">
            <.icon name="hero-rocket-launch-solid" class="size-8 text-primary" />
          </div>
        </div>
        <h2 class="font-brand text-3xl sm:text-4xl">
          READY TO <span class="text-primary">GET STARTED?</span>
        </h2>
        <p class="mt-4 text-base-content/60 text-lg max-w-xl mx-auto">
          Join FitTrackerz today and take your fitness business to the next level. It's free, fast, and packed with features.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-6 mb-8">
          <div class="flex items-center gap-1.5 text-sm text-base-content/60">
            <.icon name="hero-check-circle-solid" class="size-4 text-success" /> Free forever plan
          </div>
          <div class="flex items-center gap-1.5 text-sm text-base-content/60">
            <.icon name="hero-check-circle-solid" class="size-4 text-success" /> No credit card
          </div>
          <div class="flex items-center gap-1.5 text-sm text-base-content/60">
            <.icon name="hero-check-circle-solid" class="size-4 text-success" /> Setup in 2 min
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/register"
            class="btn btn-primary btn-lg gap-2 shadow-lg shadow-primary/25 font-bold px-8 animate-glow-pulse"
          >
            <.icon name="hero-rocket-launch-solid" class="size-5" /> Create Free Account
          </a>
          <a href="/sign-in" class="btn btn-ghost btn-lg font-semibold border border-base-300">
            Already have an account?
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<%!-- Back to Top Button --%>
<button
  id="back-to-top"
  class="fixed bottom-8 right-8 btn btn-circle btn-primary shadow-lg opacity-0 pointer-events-none transition-opacity duration-300 z-40"
  aria-label="Back to top"
>
  <.icon name="hero-arrow-up" class="size-6" />
</button>

<%!-- Footer --%>
<footer class="bg-base-200/80 backdrop-blur-sm border-t border-base-300 relative">
  <%!-- Decorative top gradient line --%>
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <%!-- Brand Column --%>
      <div>
        <a href="/" class="flex items-center gap-2 mb-4">
          <.brand_logo class="h-10 w-auto" />
        </a>
        <p class="text-base-content/60 text-sm mb-4">
          The all-in-one platform connecting gyms and members for a better fitness experience.
        </p>
        <div class="flex gap-3">
          <a href="#" class="btn btn-circle btn-ghost btn-sm" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
          <a href="#" class="btn btn-circle btn-ghost btn-sm" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
          </a>
          <a href="#" class="btn btn-circle btn-ghost btn-sm" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <%!-- Solutions Column --%>
      <div>
        <h3 class="font-bold text-base mb-4 flex items-center gap-2">
          <.icon name="hero-squares-2x2-solid" class="size-4 text-primary" /> Solutions
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/solutions/members" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              For Members
            </a>
          </li>
          <li>
            <a href="/solutions/operators" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              For Gym Operators
            </a>
          </li>
        </ul>
      </div>

      <%!-- Company Column --%>
      <div>
        <h3 class="font-bold text-base mb-4 flex items-center gap-2">
          <.icon name="hero-building-office-solid" class="size-4 text-primary" /> Company
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/about" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              About Us
            </a>
          </li>
          <li>
            <a href="/explore" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              Explore Gyms
            </a>
          </li>
          <li>
            <a href="/explore/contests" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              Contests
            </a>
          </li>
          <li>
            <a href="#" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">Contact</a>
          </li>
          <li>
            <a href="#" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">Careers</a>
          </li>
        </ul>
      </div>

      <%!-- Legal Column --%>
      <div>
        <h3 class="font-bold text-base mb-4 flex items-center gap-2">
          <.icon name="hero-shield-check-solid" class="size-4 text-primary" /> Legal
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="#" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="#" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              Terms of Service
            </a>
          </li>
          <li>
            <a href="#" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              Cookie Policy
            </a>
          </li>
          <li>
            <a href="#" class="text-base-content/60 hover:text-primary hover:underline underline-offset-4 transition-colors">
              Refund Policy
            </a>
          </li>
        </ul>
      </div>
    </div>

    <%!-- Bottom Bar --%>
    <div class="pt-8 border-t border-base-300 flex items-center justify-center">
      <p class="text-sm text-base-content/40">
        &copy; 2026 FitTrackerz. All rights reserved.
      </p>
    </div>
  </div>
</footer>
