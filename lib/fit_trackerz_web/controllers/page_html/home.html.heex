      </div>
      <div class="glass-card text-center p-8 relative group">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-primary-content text-xs font-bold px-3 py-0.5 rounded-full">STEP 2</div>
        <div class="w-16 h-16 rounded-2xl bg-secondary/10 flex items-center justify-center mx-auto mb-4 border border-secondary/20 group-hover:scale-110 transition-transform">
          <.icon name="hero-magnifying-glass-solid" class="size-8 text-secondary" />
        </div>
        <h3 class="text-xl font-semibold mb-2">Explore Nearby Gyms</h3>
        <p class="text-base-content/60 text-sm">
          Browse gyms by location, compare pricing and amenities.
        </p>
        <div class="flex justify-center gap-1 mt-4">
          <.icon name="hero-map-pin-solid" class="size-4 text-success" />
          <span class="text-xs text-base-content/40">GPS auto-detect</span>
        </div>
      </div>
      <div class="glass-card text-center p-8 relative group">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-primary-content text-xs font-bold px-3 py-0.5 rounded-full">STEP 3</div>
        <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4 border border-primary/20 group-hover:scale-110 transition-transform">
          <.icon name="hero-fire-solid" class="size-8 text-primary" />
        </div>
        <h3 class="text-xl font-semibold mb-2">Join & Train</h3>
        <p class="text-base-content/60 text-sm">
          Pick a plan that fits your budget and start your fitness journey.
        </p>
        <div class="flex justify-center gap-1 mt-4">
          <.icon name="hero-bolt-solid" class="size-4 text-success" />
          <span class="text-xs text-base-content/40">Instant access</span>
