<FitTrackerzWeb.Layouts.public_navbar />

<%!-- Hero Split-Screen Section --%>
<section class="relative min-h-screen flex items-center overflow-hidden pt-16">
  <%!-- Background – gradient with animated glows --%>
  <div class="absolute inset-0 bg-gradient-to-br from-base-100 via-base-100 to-base-200"></div>
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-primary/10 rounded-full blur-3xl animate-float-slow"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-secondary/10 rounded-full blur-3xl animate-float-slow" style="animation-delay: 2s;"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl animate-float-slow" style="animation-delay: 4s;"></div>

  <%!-- Floating Fitness Icons (decorative) --%>
