      <%!-- Scheduling (1x1) --%>
      <div class="glass-card group overflow-hidden relative p-0">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-secondary/30"></div>
        <div class="p-5">
          <div class="w-11 h-11 rounded-xl bg-secondary/10 flex items-center justify-center mb-3 group-hover:bg-secondary/20 transition-colors">
            <.icon name="hero-calendar-days-solid" class="size-5 text-secondary" />
          </div>
          <h3 class="font-bold mb-1">Class Scheduling</h3>
          <p class="text-base-content/60 text-xs leading-relaxed">
            Schedule sessions, and let members book with real-time availability.
          </p>
        </div>
      </div>

      <%!-- Workout Plans (1x1) --%>
      <div class="glass-card group overflow-hidden relative p-0">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-primary/30"></div>
        <div class="p-5">
          <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center mb-3 group-hover:bg-primary/20 transition-colors">
            <.icon name="hero-fire-solid" class="size-5 text-primary" />
          </div>
          <h3 class="font-bold mb-1">Workout Plans</h3>
          <p class="text-base-content/60 text-xs leading-relaxed">
            Create personalized plans or use templates. Track exercises, sets, reps, and rest periods.
          </p>
        </div>
      </div>

      <%!-- Diet & Nutrition (2x1 wide) --%>
      <div class="glass-card group overflow-hidden relative md:col-span-2 p-0">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-secondary/30"></div>
        <div class="p-5 flex items-start gap-4">
          <div class="w-11 h-11 rounded-xl bg-secondary/10 flex items-center justify-center shrink-0 group-hover:bg-secondary/20 transition-colors">
            <.icon name="hero-heart-solid" class="size-5 text-secondary" />
          </div>
          <div>
            <h3 class="font-bold mb-1">Diet & Nutrition</h3>
            <p class="text-base-content/60 text-xs leading-relaxed">
              Build meal plans with calorie targets, macros tracking, and dietary preferences including vegetarian, vegan, and more.
            </p>
          </div>
        </div>
      </div>

      <%!-- Billing (2x1 wide on lg, or 1x1) --%>
      <div class="glass-card group overflow-hidden relative lg:col-span-3 p-0">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-secondary/30"></div>
        <div class="p-5 flex items-start gap-4">
          <div class="w-11 h-11 rounded-xl bg-secondary/10 flex items-center justify-center shrink-0 group-hover:bg-secondary/20 transition-colors">
            <.icon name="hero-credit-card-solid" class="size-5 text-secondary" />
          </div>
          <div>
            <h3 class="font-bold mb-1">Billing & Subscriptions</h3>
            <p class="text-base-content/60 text-xs leading-relaxed">
              Flexible subscription plans from day passes to annual memberships. Track payments and manage renewals effortlessly.
            </p>
          </div>
        </div>
      </div>

      <%!-- Attendance (1x1) --%>
      <div class="glass-card group overflow-hidden relative p-0">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-primary/30"></div>
        <div class="p-5">
          <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center mb-3 group-hover:bg-primary/20 transition-colors">
            <.icon name="hero-chart-bar-solid" class="size-5 text-primary" />
          </div>
          <h3 class="font-bold mb-1">Attendance Tracking</h3>
          <p class="text-base-content/60 text-xs leading-relaxed">
            Track check-ins, monitor patterns, and keep complete visit records.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<%!-- Role Cards Section --%>
<section class="py-24 px-4 sm:px-6 lg:px-8 bg-base-200/50 relative">
  <%!-- Decorative top accent --%>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
    <div class="w-12 h-12 rounded-xl bg-base-100 border border-base-300/50 flex items-center justify-center shadow-sm rotate-45">
      <.icon name="hero-users-solid" class="size-5 text-primary -rotate-45" />
    </div>
  </div>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-brand text-3xl sm:text-4xl">
        BUILT FOR <span class="text-primary">EVERYONE</span>
      </h2>
      <p class="mt-4 text-base-content/60 text-lg max-w-2xl mx-auto">
        Whether you own a gym or just want to get fit, FitTrackerz has you covered.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 max-w-3xl mx-auto gap-8">
      <%!-- Gym Operator Card --%>
      <div class="glass-card overflow-hidden relative">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-[3rem]"></div>
        <div class="p-8 items-center text-center relative">
          <div class="w-20 h-20 rounded-3xl bg-primary/15 flex items-center justify-center mx-auto mb-4 border border-primary/20">
            <.icon name="hero-building-office-2-solid" class="size-9 text-primary" />
          </div>
          <h3 class="text-xl font-brand">GYM OPERATORS</h3>
          <ul class="text-sm text-base-content/60 space-y-2 mt-4 text-left">
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>Multi-branch management</span>
            </li>
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>Invite and manage members</span>
            </li>
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>Subscription plan creation</span>
            </li>
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>Revenue and analytics</span>
            </li>
          </ul>
          <div class="mt-6">
            <a href="/register" class="btn btn-primary btn-sm font-bold">
              Register as Operator
            </a>
          </div>
        </div>
      </div>

      <%!-- Member Card --%>
      <div class="glass-card overflow-hidden relative">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-[3rem]"></div>
        <div class="p-8 items-center text-center relative">
          <div class="w-20 h-20 rounded-3xl bg-primary/10 flex items-center justify-center mx-auto mb-4 border border-primary/20">
            <.icon name="hero-user-solid" class="size-9 text-primary" />
          </div>
          <h3 class="text-xl font-brand">MEMBERS</h3>
          <ul class="text-sm text-base-content/60 space-y-2 mt-4 text-left">
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>Book classes instantly</span>
            </li>
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>View workout plans</span>
            </li>
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>Track diet and nutrition</span>
            </li>
            <li class="flex items-start gap-2">
              <.icon name="hero-check-circle-solid" class="size-4 text-primary mt-0.5 shrink-0" />
              <span>Attendance history</span>
            </li>
          </ul>
          <div class="mt-6">
            <a href="/register" class="btn btn-primary btn-sm font-bold">Join as Member</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

