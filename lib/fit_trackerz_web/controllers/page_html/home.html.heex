            <div class="flex-1 bg-primary/20 rounded-t" style="height: 40%"></div>
            <div class="flex-1 bg-primary/30 rounded-t" style="height: 55%"></div>
            <div class="flex-1 bg-primary/40 rounded-t" style="height: 70%"></div>
            <div class="flex-1 bg-primary/50 rounded-t" style="height: 45%"></div>
            <div class="flex-1 bg-primary/60 rounded-t" style="height: 80%"></div>
            <div class="flex-1 bg-primary/70 rounded-t" style="height: 65%"></div>
            <div class="flex-1 bg-primary rounded-t" style="height: 100%"></div>
