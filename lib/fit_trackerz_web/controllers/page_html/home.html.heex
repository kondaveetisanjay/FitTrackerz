              <.icon name="hero-shield-check-solid" class="size-4 text-primary" />
            </div>
            <div>
              <p class="font-semibold text-sm">Verified Gyms</p>
              <p class="text-xs text-base-content/50">Every gym is verified for quality and safety standards</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-secondary/10 flex items-center justify-center shrink-0 mt-0.5">
