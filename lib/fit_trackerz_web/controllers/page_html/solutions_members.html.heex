      <.icon name="hero-user-solid" class="size-4" />
      <span>For Members</span>
    </div>

    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-brand leading-tight animate-fade-up stagger-1">
      Your Fitness Journey <span class="text-accent">Starts Here</span>
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-base-content/55 max-w-2xl mx-auto leading-relaxed animate-fade-up stagger-2">
      Discover top-rated gyms, book classes instantly, track your progress, and achieve your fitness goals with personalized workout and diet plans.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up stagger-3">
      <a href="/register" class="btn btn-accent btn-lg gap-2 shadow-lg shadow-accent/25 font-bold px-8 press-scale">
        <.icon name="hero-rocket-launch-solid" class="size-5" /> Join as Member
      </a>
      <a href="/explore" class="btn btn-ghost btn-lg gap-2 font-semibold">
        <.icon name="hero-magnifying-glass" class="size-5" /> Explore Gyms
      </a>
    </div>
  </div>
</section>

<%!-- Key Features Section --%>
<section class="py-24 px-4 sm:px-6 lg:px-8 bg-base-200/30">
