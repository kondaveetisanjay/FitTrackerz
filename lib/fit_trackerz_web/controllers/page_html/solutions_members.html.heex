      <div class="ft-card ft-card-hover p-6">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-secondary/15 to-secondary/5 flex items-center justify-center mb-4">
          <.icon name="hero-fire-solid" class="size-6 text-secondary" />
        </div>
        <h3 class="text-lg font-bold mb-2">Workout Plans</h3>
        <p class="text-base-content/55 leading-relaxed text-sm">
          Access personalized workout plans with exercises, sets, reps, and progress tracking.
        </p>
      </div>

      <div class="ft-card ft-card-hover p-6">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-success/15 to-success/5 flex items-center justify-center mb-4">
          <.icon name="hero-heart-solid" class="size-6 text-success" />
        </div>
        <h3 class="text-lg font-bold mb-2">Diet Plans</h3>
        <p class="text-base-content/55 leading-relaxed text-sm">
          Follow customized meal plans with calorie tracking, macro breakdowns, and dietary preference options.
        </p>
      </div>

      <div class="ft-card ft-card-hover p-6">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/15 to-primary/5 flex items-center justify-center mb-4">
          <.icon name="hero-chart-bar-solid" class="size-6 text-primary" />
        </div>
        <h3 class="text-lg font-bold mb-2">Track Progress</h3>
        <p class="text-base-content/55 leading-relaxed text-sm">
          Monitor attendance, workout completion, and fitness goals with detailed analytics and insights.
        </p>
      </div>

      <div class="ft-card ft-card-hover p-6">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-warning/15 to-warning/5 flex items-center justify-center mb-4">
          <.icon name="hero-credit-card-solid" class="size-6 text-warning" />
        </div>
        <h3 class="text-lg font-bold mb-2">Flexible Plans</h3>
        <p class="text-base-content/55 leading-relaxed text-sm">
          Choose from day passes, monthly, or annual memberships. Manage subscriptions and payments easily.
        </p>
      </div>
    </div>
  </div>
</section>

